# Matheus Elis Sway Config

# 1. Set a wallpaper on every monitor
output * bg ~/.wallpaper/5qs71paaaic71.png fill

# 2. Include our custom modules
include "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf"

# 3. Re-include sway's default configs for safety
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" )'
