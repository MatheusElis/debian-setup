# Kanshi - perfis automáticos de monitor

# Perfil: só laptop
profile laptop {
    output eDP-1 enable mode 1920x1080 position 0,0 scale 1
}

# Perfil: monitor externo à esquerda + laptop à direita
profile docked {
    output HDMI-A-1 enable mode 1920x1080 position 0,0
    output eDP-1 enable mode 1920x1080 position 1920,0
}

# Perfil: só monitor externo (laptop fechado)
profile external-only {
    output eDP-1 disable
    output HDMI-A-1 enable mode 1920x1080 position 0,0
}
